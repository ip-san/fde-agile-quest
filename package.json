{
  "name": "fde-agile-quest",
  "version": "0.1.0",
  "description": "プログラマーをFDEへリスキリングする、ルーレット駆動の判断キャンペーンPWA",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write src/ scripts/",
    "format:check": "biome format src/ scripts/",
    "lint": "biome lint src/ scripts/",
    "check:lint": "biome check src/ scripts/",
    "check": "npm run typecheck && npm run check:lint && npm run test",
    "circular": "madge --circular --extensions ts,tsx src/",
    "knip": "knip",
    "type-coverage": "type-coverage --strict --at-least 99 --ignore-files \"**/*.test.*\"",
    "cpd": "jscpd src --min-lines 5 --min-tokens 50 --ignore \"**/data/**\" --threshold 2",
    "check:all": "npm run check && npm run circular && npm run knip && npm run type-coverage && npm run cpd",
    "size": "size-limit",
    "lighthouse": "lhci autorun --config=lighthouserc.cjs",
    "test:e2e": "playwright test",
    "generate-icons": "node scripts/generate-icons.mjs",
    "gen:index": "node scripts/gen-event-index.mjs",
    "prepare": "husky"
  },
  "size-limit": [
    {
      "name": "App JS (brotli)",
      "path": "dist/assets/index-*.js",
      "limit": "164 kB"
    },
    {
      "name": "App CSS (brotli)",
      "path": "dist/assets/index-*.css",
      "limit": "10 kB"
    }
  ],
  "lint-staged": {
    "*.{ts,tsx,mjs}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.5.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@size-limit/file": "^11.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "husky": "^9.1.7",
    "jscpd": "^4.2.5",
    "jsdom": "^25.0.1",
    "knip": "^6.17.1",
    "lint-staged": "^17.0.7",
    "madge": "^8.0.0",
    "postcss": "^8.4.49",
    "sharp": "^0.35.1",
    "size-limit": "^11.2.0",
    "tailwindcss": "^4.0.0",
    "type-coverage": "^2.29.7",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^4.1.8"
  }
}
