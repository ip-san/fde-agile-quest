# ステージ済みファイルを Biome で整形＋安全な lint 自動修正（lint-staged）
npx lint-staged

# 変更に関係するテストだけ走らせる（高速）
npx vitest run --changed --reporter=dot

# 禁止パターンの検査（iOS PWA 互換: min-h-screen は min-h-dvh を使う）
# ステージ済み .tsx の「追加行」だけを対象にする（フック自身や削除行に誤反応しない）
TSX_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.tsx$')
if [ -n "$TSX_FILES" ]; then
  if git diff --cached -U0 -- $TSX_FILES | grep -q '^+.*min-h-screen'; then
    echo "❌ min-h-screen を検出 — iOS PWA 互換のため min-h-dvh を使ってください"
    exit 1
  fi
fi
